@page "/timeline"
@inject IJournalService Journal

<h3 class="mb-3">Timeline</h3>

<div class="container-fluid p-0" style="max-width:1100px;">

    <!-- Filters -->
    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-5">
                    <label class="form-label mb-1"><b>Search</b></label>
                    <input class="form-control"
                           placeholder="Search title/content..."
                           @bind-value="_q"
                           @bind-value:event="oninput" />
                </div>

                <div class="col-6 col-md-3">
                    <label class="form-label mb-1"><b>From</b></label>
                    <input class="form-control"
                           type="date"
                           @bind="_fromDt"
                           @bind:format="yyyy-MM-dd" />
                </div>

                <div class="col-6 col-md-3">
                    <label class="form-label mb-1"><b>To</b></label>
                    <input class="form-control"
                           type="date"
                           @bind="_toDt"
                           @bind:format="yyyy-MM-dd" />
                </div>

                <div class="col-12 col-md-1 d-grid">
                    <button class="btn btn-primary" @onclick="Apply">Apply</button>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 mt-3">
                <span class="badge bg-light text-dark border">Total: <b>@_total</b></span>
                <span class="badge bg-light text-dark border">Page: <b>@_page</b></span>
                <span class="badge bg-light text-dark border">Page size: <b>@_pageSize</b></span>

                @if (_fromDt != null || _toDt != null || !string.IsNullOrWhiteSpace(_q))
                {
                    <span class="badge bg-secondary">Filters active</span>
                }

                <!-- Debug helper (optional): shows what values are actually bound -->
                <span class="badge bg-light text-dark border">
                    From: <b>@(_fromDt?.ToString("yyyy-MM-dd") ?? "null")</b>
                </span>
                <span class="badge bg-light text-dark border">
                    To: <b>@(_toDt?.ToString("yyyy-MM-dd") ?? "null")</b>
                </span>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="alert alert-info">Loading entries...</div>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }
    else
    {
        <!-- Results -->
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <b>Entries</b>
                <small class="text-muted">Showing @(_items.Count) of @_total</small>
            </div>

            <div class="card-body">
                @if (_items.Count == 0)
                {
                    <p class="text-muted mb-0">No results found for the selected filters.</p>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var e in _items)
                        {
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between gap-3">
                                    <div>
                                        <div class="fw-semibold" style="font-size:1.05rem;">
                                            @(!string.IsNullOrWhiteSpace(e.Title) ? e.Title : "(No title)")
                                        </div>

                                        <div class="text-muted" style="font-size:0.9rem;">
                                            <span class="me-2"><b>Date:</b> @e.EntryDateKey</span>
                                            <span class="me-2"><b>Primary Mood:</b> @e.PrimaryMood</span>
                                            <span><b>Words:</b> @e.WordCount</span>
                                        </div>
                                    </div>

                                    <div class="text-muted" style="white-space:nowrap; font-size:0.9rem;">
                                        @e.UpdatedAt.ToString("yyyy-MM-dd HH:mm")
                                    </div>
                                </div>

                                <div class="mt-2" style="opacity:.9;">
                                    @Preview(e.ContentMarkdown, 160)
                                </div>

                                @if (!string.IsNullOrWhiteSpace(e.Category))
                                {
                                    <div class="mt-2">
                                        <span class="badge bg-secondary">@e.Category</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }

                <!-- Pagination -->
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-3">
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" @onclick="Prev" disabled="@(_page <= 1)">← Prev</button>
                        <button class="btn btn-outline-secondary" @onclick="Next" disabled="@((_page * _pageSize) >= _total)">Next →</button>
                    </div>

                    <div class="text-muted">
                        Page <b>@_page</b> of <b>@TotalPages</b>
                    </div>

                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted">Page size</span>
                        <select class="form-select form-select-sm" style="width:110px;" @bind="_pageSize">
                            <option value="5">5</option>
                            <option value="10">10</option>
                            <option value="20">20</option>
                        </select>

                        <button class="btn btn-outline-primary btn-sm" type="button" @onclick="Apply">
                            Refresh
                        </button>
                    </div>
                </div>

            </div>
        </div>
    }
</div>

@code {
    // FILTERS
    private string _q = "";
    private DateTime? _fromDt = null;
    private DateTime? _toDt = null;

    // PAGING
    private int _page = 1;
    private int _pageSize = 10;

    private List<JournalEntry> _items = new();
    private int _total;

    private bool _loading = true;
    private string _error = "";

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private static DateOnly? ToDateOnly(DateTime? dt)
        => dt.HasValue ? DateOnly.FromDateTime(dt.Value) : null;

    private async Task Load()
    {
        try
        {
            _loading = true;
            _error = "";

            var from = ToDateOnly(_fromDt);
            var to = ToDateOnly(_toDt);

            var (items, total) = await Journal.GetPagedAsync(
                _page, _pageSize,
                query: string.IsNullOrWhiteSpace(_q) ? null : _q.Trim(),
                from: from,
                to: to);

            _items = items;
            _total = total;
        }
        catch (Exception ex)
        {
            _error = $"Failed to load timeline: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Apply()
    {
        _page = 1;
        await Load();
    }

    private async Task Prev()
    {
        if (_page <= 1) return;
        _page--;
        await Load();
    }

    private async Task Next()
    {
        if ((_page * _pageSize) >= _total) return;
        _page++;
        await Load();
    }

    private int TotalPages
    {
        get
        {
            if (_pageSize <= 0) return 1;
            var pages = (int)Math.Ceiling(_total / (double)_pageSize);
            return pages <= 0 ? 1 : pages;
        }
    }

    private static string Preview(string text, int max)
    {
        if (string.IsNullOrWhiteSpace(text)) return "(No content)";
        var t = text.Replace("\r", " ").Replace("\n", " ").Trim();
        return t.Length > max ? t.Substring(0, max) + "..." : t;
    }
}
