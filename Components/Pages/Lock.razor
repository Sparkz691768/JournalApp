@page "/lock"
@using JournalApp.Services.Interfaces
@using Microsoft.AspNetCore.Components.Web
@inject ISecurityService Security
@inject NavigationManager Nav

<div class="d-flex justify-content-center align-items-center" style="min-height:75vh;">
    <div class="card shadow-sm" style="max-width:420px; width:100%;">
        <div class="card-body p-4">

            <div class="d-flex align-items-center gap-2 mb-2">
                <span style="font-size:1.3rem;">🔒</span>
                <h4 class="mb-0">Unlock Journal</h4>
            </div>

            <p class="text-muted mb-4">
                Enter your 4-digit PIN to continue.
            </p>

            @if (_loading)
            {
                <div class="d-flex align-items-center gap-2">
                    <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
                    <span class="text-muted">Checking security...</span>
                </div>
            }
            else if (!_hasPin)
            {
                <div class="alert alert-info mb-3">
                    No PIN is set. You can continue without unlocking.
                </div>

                <button type="button" class="btn btn-primary w-100" @onclick="GoHome">
                    Continue
                </button>

                <div class="text-muted mt-3" style="font-size:0.9rem;">
                    Tip: Set a PIN from Settings to enable lock on restart.
                </div>
            }
            else
            {
                <label class="form-label fw-semibold">PIN</label>
                <input class="form-control form-control-lg"
                       placeholder="••••"
                       type="password"
                       inputmode="numeric"
                       maxlength="4"
                       autocomplete="one-time-code"
                       @bind="_pin"
                       @bind:event="oninput" />

                <button type="button"
                        class="btn btn-primary w-100 mt-3"
                        disabled="@(_pin.Length != 4)"
                        @onclick="Unlock">
                    Unlock
                </button>

                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <div class="alert alert-danger mt-3 mb-0">
                        @_error
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private bool _loading = true;
    private bool _hasPin;
    private string _pin = "";
    private string _error = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _hasPin = await Security.HasPinAsync();
        }
        finally
        {
            _loading = false;
        }

    }

    private async Task Unlock()
    {
        _error = "";

        if (string.IsNullOrWhiteSpace(_pin) || _pin.Length != 4 || !_pin.All(char.IsDigit))
        {
            _error = "Please enter a 4-digit PIN.";
            return;
        }

        var ok = await Security.VerifyPinAsync(_pin);
        if (!ok)
        {
            _error = "Incorrect PIN. Please try again.";
            _pin = "";
            return;
        }

        // mark unlocked and go to Home
        Preferences.Set("unlocked", true);
        Nav.NavigateTo("/", replace: true);
    }

    private void GoHome()
    {
        // No PIN case: allow access
        Preferences.Set("unlocked", true);
        Nav.NavigateTo("/", replace: true);
    }
}
