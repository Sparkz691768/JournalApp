@using JournalApp.Services.Interfaces
@using Microsoft.AspNetCore.Components.Routing
@inject ISecurityService Security
@inject NavigationManager Nav

<Router AppAssembly="@typeof(App).Assembly"
        OnNavigateAsync="GuardNavigation">

    <Found Context="routeData">
        <AuthorizeRoute routeData="routeData" />
    </Found>

    <NotFound>
        <LayoutView Layout="@typeof(JournalApp.Components.Layout.MainLayout)">
            <p>Page not found.</p>
        </LayoutView>
    </NotFound>
</Router>

@code {
    private async Task GuardNavigation(NavigationContext context)
    {
        
        var raw = context?.Path ?? "";
        var target = raw.TrimStart('/');

        
        var qIndex = target.IndexOf('?');
        if (qIndex >= 0)
            target = target[..qIndex];

        target = target.ToLowerInvariant();

        
        if (target.StartsWith("lock") || target.StartsWith("settings"))
            return;

        var hasPin = await Security.HasPinAsync();
        var unlocked = Preferences.Get("unlocked", false);

        if (hasPin && !unlocked)
        {
            
            await Task.Yield();
            Nav.NavigateTo("/lock", replace: true);
        }
    }
}
